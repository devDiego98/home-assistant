NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://casa:casa_password@localhost:5432/casa_db

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# Frigate NVR
FRIGATE_URL=http://localhost:5000

# MQTT
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Firebase (push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

TUYA_CLIENT_ID=your_client_id_here
TUYA_CLIENT_SECRET=your_client_secret_here
TUYA_REGION=us   # or eu / cn / in — match what you picked in step 2
